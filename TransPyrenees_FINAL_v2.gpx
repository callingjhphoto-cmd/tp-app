<gpx version="1.1" creator="Trans-Pyrenees FINAL v2" xmlns="http://www.topografix.com/GPX/1/1">
<metadata><name>Begur to San Sebastian OFF-ROAD FINAL (route+food+vistas+fuel+confirmed camps)</name></metadata>
<wpt lat="41.954" lon="3.207"><name>START Begur</name><sym>Flag, Blue</sym></wpt>
<wpt lat="42.267" lon="2.96"><name>Figueres GEAR (Outlet del Motero/Tecnimoto)</name><sym>Flag, Blue</sym></wpt>
<wpt lat="42.3591" lon="-0.7448"><name>VISTA Mallos de Riglos - SUNSET, red towers</name><sym>Scenic Area</sym></wpt>
<wpt lat="43.392" lon="-1.792"><name>FINISH VISTA Cabo Higuer lighthouse - sunset</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.0966" lon="0.697"><name>VISTA Congost de Mont-rebei gorge (S detour)</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.49" lon="0.05"><name>VISTA Mirador Canon de Anisclo (Ordesa)</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.419" lon="0.14"><name>VISTA Ainsa Plaza Mayor + ramparts - pre-sunset</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.79" lon="-0.73"><name>VISTA Selva de Oza/Guarrinza glacial valley</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.65" lon="-1.3"><name>VISTA Foz de Lumbier - gorge + vultures (midday)</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.69" lon="-1.27"><name>VISTA Foz de Arbayun mirador Iso</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.92" lon="-0.78"><name>VISTA Belagua valley / Larra karst</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.98" lon="-1.07"><name>VISTA Mirador de Pikatua - Irati forest</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.76" lon="-0.838"><name>VISTA Anso stone village</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.741" lon="-0.752"><name>VISTA Hecho stone village</name><sym>Scenic Area</sym></wpt>
<wpt lat="42.2666767" lon="2.9600095"><name>FOOD Mesón Asador</name><desc>Empordà charcoal grills, weekday menú. Good value (avoid Dalí-museum strip). https://www.google.com/maps/search/?api=1&amp;query=Mes%C3%B3n%20Asador%20Figueres</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.375" lon="2.305"><name>FOOD Can Jepet</name><desc>Pyrenees mountain cooking — civet de jabalí (wild boar). TA 4.3, #1 in Setcases. (approx loc) https://www.google.com/maps/search/?api=1&amp;query=Can%20Jepet%20Setcases</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.452" lon="1.078"><name>FOOD Lo Pigal Casa Kiko</name><desc>Pallars traditional — lamb, carne a la piedra. TA 4.5. Mains ~€20-30. Reserve. (approx loc) https://www.google.com/maps/search/?api=1&amp;query=Lo%20Pigal%20Casa%20Kiko%20Llessui</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.4099754" lon="1.12952"><name>FOOD Restaurant Pessets</name><desc>Mountain trout, venison, civets. Guía Repsol. Mid-value. https://www.google.com/maps/search/?api=1&amp;query=Restaurant%20Pessets%20Sort</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.2421314" lon="0.9654046"><name>FOOD Bar Pirineus</name><desc>Village bar, well-priced midday menú; conill guisat (rabbit stew). https://www.google.com/maps/search/?api=1&amp;query=Bar%20Pirineus%20La%20Pobla%20de%20Segur</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.741" lon="-0.752"><name>FOOD Casa Blasquico Gaby</name><desc>Best table in the valley — refined Aragonese. Set ~€16. TA Travellers&#x27; Choice. Book. (approx loc) https://www.google.com/maps/search/?api=1&amp;query=Casa%20Blasquico%20Gaby%20Hecho</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.8243342" lon="-0.8321405"><name>FOOD Borda Chiquín</name><desc>Converted mountain borda — migas de pastor &amp; grilled meats. https://www.google.com/maps/search/?api=1&amp;query=Borda%20Chiqu%C3%ADn%20Ans%C3%B3</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.5695965" lon="-0.5533162"><name>FOOD La Cocina Aragonesa</name><desc>Traditional Aragonese. Menú del día €16. Ternasco asado. https://www.google.com/maps/search/?api=1&amp;query=La%20Cocina%20Aragonesa%20Jaca</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.855" lon="-0.927"><name>FOOD Casa Tapia</name><desc>Valley standout — trout with ham, Roncal DO cheese. Menú €14.50. Best in Roncal. (approx loc) https://www.google.com/maps/search/?api=1&amp;query=Casa%20Tapia%20Isaba</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.9379474" lon="-0.8574285"><name>FOOD Venta de Juan Pito</name><desc>Family-run traditional Roncalés cooking, local produce. https://www.google.com/maps/search/?api=1&amp;query=Venta%20de%20Juan%20Pito%20Isaba</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.908" lon="-1.088"><name>FOOD Asador Kixkia</name><desc>Navarrese cider-house asador — chuletón a la brasa. TA 4.2, #1 in Ochagavía. Biker stop. (approx loc) https://www.google.com/maps/search/?api=1&amp;query=Asador%20Kixkia%20Ochagav%C3%ADa</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.9047152" lon="-1.0900861"><name>FOOD Restaurante Auñamendi</name><desc>Cordero al chilindrón, trout. Weekday menú €16. TA 3.8. https://www.google.com/maps/search/?api=1&amp;query=Restaurante%20Au%C3%B1amendi%20Ochagav%C3%ADa</desc><sym>Restaurant</sym></wpt>
<wpt lat="43.2945896" lon="-1.9669562"><name>FOOD Borda Berri</name><desc>Parte Vieja pintxos benchmark — veal cheek, rib kebab. ~€15pp. Made to order. https://www.google.com/maps/search/?api=1&amp;query=Borda%20Berri%20San%20Sebasti%C3%A1n</desc><sym>Restaurant</sym></wpt>
<wpt lat="43.3238831" lon="-1.9837014"><name>FOOD Bar Néstor</name><desc>Cult bar — txuleta steak, tomato salad, one daily tortilla (ask early). https://www.google.com/maps/search/?api=1&amp;query=Bar%20N%C3%A9stor%20San%20Sebasti%C3%A1n</desc><sym>Restaurant</sym></wpt>
<wpt lat="43.3239943" lon="-1.9857674"><name>FOOD Gandarias</name><desc>Reliable old-town all-rounder — Gilda, txuleta skewers, foie toast. https://www.google.com/maps/search/?api=1&amp;query=Gandarias%20San%20Sebasti%C3%A1n</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.3606682" lon="0.1614066"><name>FOOD Casa Falceto</name><desc>4.6 stars ~680 rev - ternasco/regional, VALUE pick (replaces Bodegas)</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.4176032" lon="0.138185"><name>FOOD Restaurante Callizo</name><desc>1 Michelin star 2026 - tasting menu EUR95-110 SPLURGE</desc><sym>Restaurant</sym></wpt>
<wpt lat="41.971687" lon="3.2108009"><name>FOOD Restaurant Costa Brava</name><desc>START seafood - arros de bogavante / suquet de peix</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.7270362" lon="-0.9948217"><name>FOOD Quesos Larra</name><desc>BUY Queso Roncal DOP at source - best detour buy</desc><sym>Restaurant</sym></wpt>
<wpt lat="43.3245012" lon="-1.9852992"><name>FOOD La Cuchara de San Telmo</name><desc>Pintxos: carrillera de ternera + foie a la plancha</desc><sym>Restaurant</sym></wpt>
<wpt lat="42.358" lon="1.459"><name>FUEL CHEAPEST Esclatoil La Seu ~EUR1.42 - BRIM IT</name><sym>Gas Station</sym></wpt>
<wpt lat="42.247" lon="0.968"><name>FUEL La Pobla - before Boumort</name><sym>Gas Station</sym></wpt>
<wpt lat="42.419" lon="0.137"><name>FUEL Ainsa</name><sym>Gas Station</sym></wpt>
<wpt lat="42.57" lon="-0.549"><name>FUEL Jaca - fill tank + 3-5L bottle</name><sym>Gas Station</sym></wpt>
<wpt lat="42.741" lon="-0.752"><name>FUEL Hecho Moeve A-176 07-14/16-20h tel974375321 - LAST before Oza/Anso!</name><sym>Gas Station</sym></wpt>
<wpt lat="42.82" lon="-0.95"><name>FUEL Urzainqui/Isaba - LAST before Belagua</name><sym>Gas Station</sym></wpt>
<wpt lat="42.305" lon="2.172"><name>CAMP Vall de Ribes tel972728820 ~EUR20-26 (open June)</name><sym>Campground</sym></wpt>
<wpt lat="42.41" lon="1.132"><name>CAMP Noguera Pallaresa Sort tel973620820 ~EUR20-25 (confirm)</name><sym>Campground</sym></wpt>
<wpt lat="42.419" lon="0.141"><name>CAMP Camping Ainsa tel974500260 ~EUR17-19 moto-friendly</name><sym>Campground</sym></wpt>
<wpt lat="42.741" lon="-0.752"><name>CAMP Valle de Hecho tel974375361 ~EUR15 cheapest all-year</name><sym>Campground</sym></wpt>
<wpt lat="43.312" lon="-2.04"><name>CAMP Igueldo San Sebastian tel943214502 EUR17 early-June</name><sym>Campground</sym></wpt>
